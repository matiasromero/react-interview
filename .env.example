# URL del backend dotnet-interview que el dev server proxiea bajo /api.
# - En devcontainer (default): el backend corre en su propio devcontainer y
#   port-forwardea :7027 al host. Desde el container del front, host.docker.internal
#   resuelve al host de macOS/Windows (Docker Desktop), por lo que ambos containers
#   se "encuentran" rebotando por el host.
# - Fuera del devcontainer (npm run dev directo en el host): usar
#   https://localhost:7027
VITE_API_PROXY_TARGET=https://host.docker.internal:7027
